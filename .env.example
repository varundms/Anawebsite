# Copy to .env (same Supabase project as DND site; different bucket).
# Project ref: qfeuxyuyxjkmqjpiknes
#
# How the live site uses Supabase: HTML stays static; `npm run build` rewrites asset paths to
# public Storage URLs (SUPABASE_URL + STORAGE_PUBLIC_BUCKET). The browser loads images/videos
# from that CDN. There is no Supabase JS client in the pages for DB/CMS content—only Storage URLs.
# sql/storage-anna-site-images.sql is optional DDL for the bucket/policies (not media binaries).

SUPABASE_URL=https://qfeuxyuyxjkmqjpiknes.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_PUBLIC_BUCKET=anna-site-images

# Optional full public URL (trailing slash)
# PUBLIC_SITE_IMAGES_BASE=https://qfeuxyuyxjkmqjpiknes.supabase.co/storage/v1/object/public/anna-site-images/

# Vercel: vercel.json supplies SUPABASE_URL + STORAGE_PUBLIC_BUCKET at build time (same pattern as DND site).
# For uploads only: set SUPABASE_ANON_KEY or SUPABASE_SERVICE_ROLE_KEY locally in .env (never commit).
